{
  "name": "gerenciador-de-jogos-zerados",
  "version": "1.0.0",
  "description": "Aplicativo desktop em Electron para gerenciar jogos zerados",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win" 
  },
  "build": {
    "appId": "com.seunome.jogoszerados",
    "productName": "Jogos Zerados",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    }
  },
  "keywords": [ "electron", "games", "json", "desktop" ],
  "author": "Seu Nome",
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.0.0"
  }
}